VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Web Push (FCM) — Firebase Console → Project settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# Optional Firestore notation AI cache (merge firestore.rules.notationAiCache, then deploy rules).
# Use 0 until rules are live to avoid permission-denied / console RPC noise.
# VITE_NOTATION_AI_CACHE=0

# Optional: raise Firebase JS log threshold (error | silent) to hide Firestore RestConnection WARN lines.
# VITE_FIREBASE_LOG_LEVEL=error

# Groq (OpenAI-compatible chat completions)
VITE_GROQ_API_KEY=
VITE_GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
