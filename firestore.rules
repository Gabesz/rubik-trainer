rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /notationMoveAiCache/{docId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/notationMoveAiCache/$(docId))
        && request.resource.data.keys().hasAll(['text', 'move', 'locale', 'promptVersion', 'updatedAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.move is string
        && request.resource.data.move.size() <= 32
        && request.resource.data.locale is string
        && request.resource.data.locale.size() >= 2
        && request.resource.data.locale.size() <= 16
        && request.resource.data.promptVersion == '2'
        && request.resource.data.updatedAt is timestamp;
      allow update, delete: if false;
    }

    match /userEngagement/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
